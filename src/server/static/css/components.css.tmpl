/* ============================================
   PASTEBIN - components.css
   Shared UI components: buttons, forms, toasts,
   loading/empty states, theme toggle, banners.
   Load order (AI.md PART 16): common -> components -> public
   ============================================ */

/* ============================================
   Buttons
   ============================================ */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border-radius: var(--radius-lg);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
    font-family: var(--font-sans);
}

.btn-primary {
    background: var(--color-accent-gradient);
    color: var(--color-on-accent);
    box-shadow: 0 2px 12px var(--color-accent-glow);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px var(--color-accent-glow);
    color: var(--color-on-accent);
}

.btn-secondary {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
}

.btn-secondary:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
}

.btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--font-size-base);
    border-radius: var(--radius-xl);
}


/* ============================================
   Forms
   ============================================ */
.form-section {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    margin-bottom: var(--space-8);
}

.form-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
}

.form-group {
    margin-bottom: var(--space-5);
}

.form-group.full-width {
    grid-column: 1 / -1;
}

.form-label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
}

.form-input,
.form-select {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-base);
    font-family: var(--font-sans);
    color: var(--color-text-primary);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
}

.form-input:focus,
.form-select:focus {
    outline: none;
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
}

.form-input::placeholder {
    color: var(--color-text-muted);
}

/* File input: style the native picker button to match .btn-secondary */
.form-input[type="file"] {
    padding: var(--space-2);
    cursor: pointer;
}

.form-input[type="file"]::file-selector-button {
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    margin-right: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
}

.form-input[type="file"]::file-selector-button:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
}

/* RTL: the picker button sits to the right of the filename */
[dir="rtl"] .form-input[type="file"]::file-selector-button {
    margin-right: 0;
    margin-left: var(--space-4);
}

.form-actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
}


/* ============================================
   Loading & Empty States
   ============================================ */
.loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) 0;
}

.loading-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-accent-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading-text {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

.empty-state {
    text-align: center;
    padding: var(--space-16) 0;
}

.empty-icon {
    font-size: 64px;
    margin-bottom: var(--space-4);
    opacity: 0.3;
}

.empty-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-2);
}

.empty-description {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
}


/* ============================================
   Result Cards Extended
   ============================================ */
.result-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    gap: var(--space-3);
}

.result-card-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text-primary);
}

.result-card-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-xs);
    font-weight: 700;
    background: var(--color-accent-gradient);
    color: var(--color-on-accent);
    border-radius: var(--radius-full);
    flex-shrink: 0;
}

.result-card-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
}

@media (min-width: 481px) {
    .result-card-body {
        grid-template-columns: repeat(3, 1fr);
    }
}

.result-card-stat {
    text-align: center;
    padding: var(--space-3);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
}

.result-card-stat-label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
}

.result-card-stat-value {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    font-family: var(--font-mono);
}

.result-card-stat-highlight {
    background: var(--color-accent-tint-strong);
}

.result-card-stat-highlight .result-card-stat-value {
    color: var(--color-accent-primary);
}

.result-card-featured {
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 20px var(--color-accent-glow);
}

/* ============================================
   Loading & Empty States Extended
   ============================================ */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) 0;
    color: var(--color-text-muted);
}

.loading-state p {
    margin-top: var(--space-4);
    font-size: var(--font-size-sm);
}

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-12) 0;
}

.empty-state-icon {
    font-size: 64px;
    margin-bottom: var(--space-4);
    opacity: 0.5;
}

.empty-state-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
}

.empty-state-description {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}


/* ============================================
   Toast Notification System (PART 16)
   ============================================ */
#toast-container {
    position: fixed;
    bottom: var(--space-4);
    right: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    z-index: 10000;
    pointer-events: none;
}

.toast {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    box-shadow: var(--shadow-lg);
    pointer-events: auto;
    animation: toastIn 0.2s ease forwards;
    min-width: 200px;
    max-width: 400px;
}

.toast--info { border-left: 4px solid var(--color-info); }
.toast--success { border-left: 4px solid var(--color-success); }
.toast--warning { border-left: 4px solid var(--color-warning); }
.toast--error { border-left: 4px solid var(--color-error); }

@keyframes toastIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes toastOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(8px); }
}

.toast--dismissing {
    animation: toastOut 0.2s ease forwards;
}


/* ============================================
   Theme Toggle Button (PART 16)
   ============================================ */
.theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    cursor: pointer;
    font-size: 18px;
    transition: all var(--transition-fast);
    flex-shrink: 0;
}

.theme-toggle:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
    border-color: var(--color-border-hover);
}

/* ============================================
   Offline Indicator (PART 16)
   ============================================ */
#offline-indicator {
    position: fixed;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    padding: var(--space-2) var(--space-5);
    background: var(--color-warning);
    color: var(--color-text-inverse);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    z-index: 9000;
    box-shadow: var(--shadow-md);
}

/* ============================================
   SW Update Banner (PART 16)
   ============================================ */
.sw-update-banner {
    position: fixed;
    bottom: var(--space-4);
    right: var(--space-4);
    background: var(--accent, var(--color-accent-primary));
    color: var(--color-on-accent);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    display: flex;
    gap: var(--space-2);
    align-items: center;
    font-size: var(--font-size-sm);
    z-index: 9999;
    box-shadow: var(--shadow-lg);
}

.sw-update-banner__btn-apply {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: inherit;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
}

.sw-update-banner__btn-apply:hover {
    background: rgba(255, 255, 255, 0.35);
}

.sw-update-banner__btn-dismiss {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: var(--space-1);
}


/* ============================================
   Cookie Consent Banner and Preferences (PART 31)
   ============================================ */

.cookie-banner {
    position: fixed;
    left: 0;
    right: 0;
    width: 100%;
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    border-top: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    z-index: 9990;
}

.cookie-banner-bottom {
    bottom: 0;
}

.cookie-banner-top {
    top: 0;
    border-top: none;
    border-bottom: 1px solid var(--color-border);
}

.cookie-banner-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-4);
    max-width: 1100px;
    margin: 0 auto;
}

.cookie-message {
    text-align: center;
    font-size: var(--font-size-sm);
    line-height: 1.5;
}

.cookie-banner .policy-link {
    color: var(--color-accent-primary);
    text-decoration: underline;
}

.cookie-banner .policy-link:hover {
    color: var(--color-accent-hover);
}

.cookie-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    flex-shrink: 0;
}

.cookie-banner button {
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    font-size: var(--font-size-sm);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--transition-fast), opacity var(--transition-fast);
}

.cookie-banner .btn-decline,
.cookie-banner .btn-preferences,
.cookie-banner .btn-do-not-sell {
    background: transparent;
    border: 1px solid var(--color-border-hover);
    color: var(--color-text-primary);
}

.cookie-banner .btn-decline:hover,
.cookie-banner .btn-preferences:hover,
.cookie-banner .btn-do-not-sell:hover {
    background: var(--color-bg-hover);
}

.cookie-banner .btn-accept {
    background: var(--color-accent-primary);
    border: 1px solid var(--color-accent-primary);
    color: var(--color-on-accent);
    font-weight: 600;
}

.cookie-banner .btn-accept:hover {
    background: var(--color-accent-hover);
}

.cookie-modal-overlay {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: rgba(0, 0, 0, 0.6);
    z-index: 10010;
}

.cookie-modal {
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow-y: auto;
    padding: var(--space-6);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
}

.cookie-modal-title {
    margin: 0 0 var(--space-5);
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
}

.cookie-category {
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
}

.cookie-category-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-height: 44px;
    cursor: pointer;
}

.cookie-category-head input[type="checkbox"] {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    accent-color: var(--color-accent-primary);
}

.cookie-category-head input[type="checkbox"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.cookie-category-label {
    font-weight: 600;
    color: var(--color-text-primary);
}

.cookie-category-desc {
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
}

.cookie-modal-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: flex-end;
    margin-top: var(--space-6);
}

.cookie-modal-actions button {
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    font-size: var(--font-size-sm);
    border-radius: var(--radius-sm);
    cursor: pointer;
}

.cookie-modal-actions .btn-decline {
    background: transparent;
    border: 1px solid var(--color-border-hover);
    color: var(--color-text-primary);
}

.cookie-modal-actions .btn-decline:hover {
    background: var(--color-bg-hover);
}

.cookie-modal-actions .btn-accept {
    background: var(--color-accent-primary);
    border: 1px solid var(--color-accent-primary);
    color: var(--color-on-accent);
    font-weight: 600;
}

.cookie-modal-actions .btn-accept:hover {
    background: var(--color-accent-hover);
}

@media (min-width: 768px) {
    .cookie-banner-content {
        flex-direction: row;
        justify-content: space-between;
        gap: var(--space-8);
        padding: var(--space-4) var(--space-6);
    }

    .cookie-message {
        text-align: left;
    }
}


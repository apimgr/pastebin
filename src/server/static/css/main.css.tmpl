/* ============================================
   PASTEBIN - Professional UI Design System
   Modern, Clean, Professional Design
   ============================================ */

/* CSS Custom Properties - Design Tokens */
:root {
    /* Canonical palette (PART 16) — rendered server-side from
       src/common/theme/colors.go (theme.ThemePaletteDark), the single
       source of truth for color values shared across Web CSS, TUI,
       Swagger, and GraphQL (AI.md:24320). */
    --bg: {{.Dark.Background}};
    --fg: {{.Dark.Foreground}};
    --accent: {{.Dark.Primary}};

    /* Colors - Dark Theme (Default) */
    --color-bg-primary: {{.Dark.Background}};
    --color-bg-secondary: {{.Dark.SurfaceAlt}};
    --color-bg-tertiary: {{.Dark.Background}};
    --color-bg-elevated: {{.Dark.Surface}};
    --color-bg-hover: {{.Dark.Border}};

    --color-text-primary: {{.Dark.Foreground}};
    --color-text-secondary: {{.Dark.Foreground}};
    --color-text-muted: {{.Dark.Muted}};
    --color-text-inverse: {{.Dark.Background}};

    --color-accent-primary: {{.Dark.Primary}};
    --color-accent-secondary: {{.Dark.Accent}};
    --color-accent-gradient: linear-gradient(135deg, {{.Dark.Primary}} 0%, {{.Dark.Accent}} 100%);
    --color-accent-hover: {{.Dark.Primary}};
    --color-accent-glow: rgba(137, 180, 250, 0.4);

    --color-success: {{.Dark.Success}};
    --color-warning: {{.Dark.Warning}};
    --color-error: {{.Dark.Error}};
    --color-info: {{.Dark.Info}};

    --color-border: rgba(255, 255, 255, 0.08);
    --color-border-hover: rgba(255, 255, 255, 0.15);
    --color-border-focus: var(--color-accent-primary);

    /* Text color rendered on top of accent / status fills */
    --color-on-accent: #ffffff;

    /* Translucent surface overlay used behind the sticky header */
    --color-surface-blur: rgba(30, 30, 46, 0.85);

    /* Tinted status / accent backgrounds (subtle fills) */
    --color-accent-tint: rgba(137, 180, 250, 0.1);
    --color-accent-tint-strong: rgba(137, 180, 250, 0.15);
    --color-success-tint: rgba(16, 185, 129, 0.15);
    --color-success-tint-soft: rgba(16, 185, 129, 0.1);
    --color-success-tint-12: rgba(16, 185, 129, 0.12);
    --color-info-tint: rgba(59, 130, 246, 0.15);
    --color-warning-tint: rgba(245, 158, 11, 0.15);
    --color-warning-tint-12: rgba(245, 158, 11, 0.12);
    --color-error-tint: rgba(239, 68, 68, 0.15);
    --color-error-tint-soft: rgba(239, 68, 68, 0.1);
    --color-error-tint-12: rgba(239, 68, 68, 0.12);
    --color-error-strong: #dc2626;

    /* Shadows */
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 40px var(--color-accent-glow);

    /* Typography */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', 'SF Mono', Consolas, monospace;

    --font-size-xs: 0.75rem;
    --font-size-sm: 0.875rem;
    --font-size-base: 1rem;
    --font-size-lg: 1.125rem;
    --font-size-xl: 1.25rem;
    --font-size-2xl: 1.5rem;
    --font-size-3xl: 2rem;
    --font-size-4xl: 2.5rem;
    --font-size-5xl: 3.5rem;

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-5: 1.25rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-10: 2.5rem;
    --space-12: 3rem;
    --space-16: 4rem;
    --space-20: 5rem;

    /* Border Radius */
    --radius-sm: 0.375rem;
    --radius-md: 0.5rem;
    --radius-lg: 0.75rem;
    --radius-xl: 1rem;
    --radius-2xl: 1.5rem;
    --radius-full: 9999px;

    /* Transitions */
    --transition-fast: 150ms ease;
    --transition-base: 200ms ease;
    --transition-slow: 300ms ease;
}

/* Auto Theme (PART 16, AI.md 23298): pure CSS — when the server renders
   html.theme-auto and the OS prefers light, override the dark-default tokens */
@media (prefers-color-scheme: light) {
    html.theme-auto {
        --bg: {{.Light.Background}};
        --fg: {{.Light.Foreground}};
        --accent: {{.Light.Primary}};

        --color-bg-primary: {{.Light.Background}};
        --color-bg-secondary: {{.Light.SurfaceAlt}};
        --color-bg-tertiary: {{.Light.Background}};
        --color-bg-elevated: {{.Light.Surface}};
        --color-bg-hover: {{.Light.Border}};

        --color-text-primary: {{.Light.Foreground}};
        --color-text-secondary: {{.Light.Foreground}};
        --color-text-muted: {{.Light.Muted}};
        --color-text-inverse: {{.Light.Background}};

        --color-accent-primary: {{.Light.Primary}};
        --color-accent-secondary: {{.Light.Accent}};
        --color-accent-gradient: linear-gradient(135deg, {{.Light.Primary}} 0%, {{.Light.Accent}} 100%);
        --color-accent-hover: {{.Light.Primary}};

        --color-success: {{.Light.Success}};
        --color-warning: {{.Light.Warning}};
        --color-error: {{.Light.Error}};
        --color-info: {{.Light.Info}};

        --color-border: rgba(0, 0, 0, 0.08);
        --color-border-hover: rgba(0, 0, 0, 0.15);

        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
        --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);

        --color-surface-blur: rgba(255, 255, 255, 0.9);
    }
}

/* Light Theme (PART 16, AI.md 23277) — server renders class="theme-light" on <html> */
html.theme-light {
    --bg: {{.Light.Background}};
    --fg: {{.Light.Foreground}};
    --accent: {{.Light.Primary}};

    --color-bg-primary: {{.Light.Background}};
    --color-bg-secondary: {{.Light.SurfaceAlt}};
    --color-bg-tertiary: {{.Light.Background}};
    --color-bg-elevated: {{.Light.Surface}};
    --color-bg-hover: {{.Light.Border}};

    --color-text-primary: {{.Light.Foreground}};
    --color-text-secondary: {{.Light.Foreground}};
    --color-text-muted: {{.Light.Muted}};
    --color-text-inverse: {{.Light.Background}};

    --color-accent-primary: {{.Light.Primary}};
    --color-accent-secondary: {{.Light.Accent}};
    --color-accent-gradient: linear-gradient(135deg, {{.Light.Primary}} 0%, {{.Light.Accent}} 100%);
    --color-accent-hover: {{.Light.Primary}};

    --color-success: {{.Light.Success}};
    --color-warning: {{.Light.Warning}};
    --color-error: {{.Light.Error}};
    --color-info: {{.Light.Info}};

    --color-border: rgba(0, 0, 0, 0.08);
    --color-border-hover: rgba(0, 0, 0, 0.15);

    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);

    --color-surface-blur: rgba(255, 255, 255, 0.9);
}

/* ============================================
   Base & Reset
   ============================================ */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    line-height: 1.6;
    color: var(--color-text-primary);
    background: var(--color-bg-primary);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text-primary);
}

a {
    color: var(--color-accent-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
}

a:hover {
    color: var(--color-accent-hover);
}

code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-bg-tertiary);
    padding: 0.2em 0.4em;
    border-radius: var(--radius-sm);
}

/* ============================================
   Header / Navigation
   ============================================ */
.header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface-blur);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--color-border);
}

.nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6);
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    text-decoration: none;
}

.nav-brand:hover {
    color: var(--color-text-primary);
}

.nav-brand-icon {
    width: 40px;
    height: 40px;
    background: var(--color-accent-gradient);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
}

.nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
}

.nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
}

.nav-link:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-hover);
}

.nav-link.active {
    color: var(--color-accent-primary);
    background: var(--color-accent-tint);
}

/* ============================================
   Main Content
   ============================================ */
main {
    flex: 1;
    padding: var(--space-8) 0;
}

.container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6);
}

.container-sm {
    max-width: 720px;
}

.container-lg {
    max-width: 1400px;
}

/* ============================================
   Hero Section
   ============================================ */
.hero {
    text-align: center;
    padding: var(--space-16) 0 var(--space-12);
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 1000px;
    background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 60%);
    pointer-events: none;
    opacity: 0.4;
}

.hero-content {
    position: relative;
    z-index: 1;
}

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
}

.hero-badge-dot {
    width: 8px;
    height: 8px;
    background: var(--color-success);
    border-radius: 50%;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(1.1); }
}

.hero-title {
    font-size: var(--font-size-5xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
}

.hero-title-gradient {
    background: var(--color-accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-description {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-8);
    line-height: 1.7;
}

.hero-actions {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
}

.hero-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-16);
}

.hero-stat {
    text-align: center;
}

.hero-stat-value {
    font-size: var(--font-size-4xl);
    font-weight: 700;
    color: var(--color-text-primary);
    font-variant-numeric: tabular-nums;
    line-height: 1;
}

.hero-stat-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-top: var(--space-2);
}

/* ============================================
   Feature Cards
   ============================================ */
.features {
    padding: var(--space-12) 0;
}

.section-header {
    text-align: center;
    margin-bottom: var(--space-10);
}

.section-title {
    font-size: var(--font-size-3xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
}

.section-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
}

.feature-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    text-align: center;
    transition: all var(--transition-base);
    cursor: pointer;
    text-decoration: none;
    display: block;
}

.feature-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent-primary);
    box-shadow: var(--shadow-glow);
}

.feature-icon {
    width: 72px;
    height: 72px;
    margin: 0 auto var(--space-5);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    transition: all var(--transition-base);
}

.feature-card:hover .feature-icon {
    background: var(--color-accent-gradient);
    transform: scale(1.1);
}

.feature-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-3);
    color: var(--color-text-primary);
}

.feature-description {
    color: var(--color-text-secondary);
    font-size: var(--font-size-sm);
    line-height: 1.6;
}

/* ============================================
   Buttons
   ============================================ */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--font-size-sm);
    font-weight: 600;
    border-radius: var(--radius-lg);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
    font-family: var(--font-sans);
}

.btn-primary {
    background: var(--color-accent-gradient);
    color: var(--color-on-accent);
    box-shadow: 0 2px 12px var(--color-accent-glow);
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px var(--color-accent-glow);
    color: var(--color-on-accent);
}

.btn-secondary {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
}

.btn-secondary:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
    color: var(--color-text-primary);
}

.btn-lg {
    padding: var(--space-4) var(--space-8);
    font-size: var(--font-size-base);
    border-radius: var(--radius-xl);
}

/* ============================================
   Search Section
   ============================================ */
.search-section {
    padding: var(--space-12) 0;
}

.search-container {
    max-width: 800px;
    margin: 0 auto;
}

.search-box {
    position: relative;
    margin-bottom: var(--space-8);
}

.search-input {
    width: 100%;
    padding: var(--space-5) var(--space-6);
    padding-left: 56px;
    font-size: var(--font-size-lg);
    font-family: var(--font-sans);
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-2xl);
    transition: all var(--transition-base);
}

.search-input:focus {
    outline: none;
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 0 4px var(--color-accent-glow);
}

.search-input::placeholder {
    color: var(--color-text-muted);
}

.search-icon {
    position: absolute;
    left: var(--space-5);
    top: 50%;
    transform: translateY(-50%);
    font-size: 20px;
    color: var(--color-text-muted);
}

.search-btn {
    position: absolute;
    right: var(--space-2);
    top: 50%;
    transform: translateY(-50%);
}

/* ============================================
   Forms
   ============================================ */
.form-section {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    margin-bottom: var(--space-8);
}

.form-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-6);
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
}

.form-group {
    margin-bottom: var(--space-5);
}

.form-group.full-width {
    grid-column: 1 / -1;
}

.form-label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
}

.form-input,
.form-select {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    font-size: var(--font-size-base);
    font-family: var(--font-sans);
    color: var(--color-text-primary);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
}

.form-input:focus,
.form-select:focus {
    outline: none;
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 0 3px var(--color-accent-glow);
}

.form-input::placeholder {
    color: var(--color-text-muted);
}

/* File input: style the native picker button to match .btn-secondary */
.form-input[type="file"] {
    padding: var(--space-2);
    cursor: pointer;
}

.form-input[type="file"]::file-selector-button {
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    margin-right: var(--space-4);
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
}

.form-input[type="file"]::file-selector-button:hover {
    background: var(--color-bg-hover);
    border-color: var(--color-border-hover);
}

/* RTL: the picker button sits to the right of the filename */
[dir="rtl"] .form-input[type="file"]::file-selector-button {
    margin-right: 0;
    margin-left: var(--space-4);
}

.form-actions {
    display: flex;
    gap: var(--space-3);
    margin-top: var(--space-6);
}

/* ============================================
   Results
   ============================================ */
.results-section {
    margin-top: var(--space-8);
}

.results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-5);
}

.results-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
}

.results-count {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
}

.results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: var(--space-4);
}

.result-card {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    transition: all var(--transition-fast);
}

.result-card:hover {
    border-color: var(--color-accent-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}

.result-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-3);
}

.result-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text-primary);
}

.result-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-2);
    font-size: var(--font-size-xs);
    font-weight: 600;
    background: var(--color-accent-tint-strong);
    color: var(--color-accent-primary);
    border-radius: var(--radius-sm);
}

.result-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
}

.result-meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
}

.result-meta-icon {
    font-size: 16px;
    opacity: 0.7;
}

/* ============================================
   API Documentation
   ============================================ */
.api-section {
    margin-bottom: var(--space-10);
}

.api-section-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
}

.endpoint {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
    transition: all var(--transition-fast);
}

.endpoint:hover {
    border-color: var(--color-border-hover);
}

.endpoint-method {
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-xs);
    font-weight: 700;
    font-family: var(--font-mono);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    flex-shrink: 0;
}

.endpoint-method.get {
    background: var(--color-success-tint);
    color: var(--color-success);
}

.endpoint-method.post {
    background: var(--color-info-tint);
    color: var(--color-info);
}

.endpoint-content {
    flex: 1;
    min-width: 0;
}

.endpoint-path {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    margin-bottom: var(--space-1);
}

.endpoint-description {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

/* Code Blocks */
.code-block {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin: var(--space-4) 0;
}

.code-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
}

.code-lang {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.code-copy {
    padding: var(--space-1) var(--space-2);
    font-size: var(--font-size-xs);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
}

.code-copy:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
}

.code-content {
    padding: var(--space-4);
    overflow-x: auto;
}

.code-content pre {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--color-text-primary);
}

/* ============================================
   Footer
   ============================================ */
.footer {
    background: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    padding: var(--space-8) 0;
    margin-top: auto;
}

.footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    text-align: center;
}

/* Operator custom branding rendered above the default footer (PART 16) */
.footer-brand {
    max-width: 100%;
    color: var(--color-text-secondary, var(--color-text-primary));
    font-size: var(--font-size-sm);
    overflow-wrap: break-word;
    word-break: break-word;
}

/* Tor onion address row — icon, monospace address box, copy button */
.footer-onion {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    max-width: 100%;
}

.footer-onion-icon {
    font-size: 20px;
    flex-shrink: 0;
}

.footer-onion-address {
    background: var(--color-bg-tertiary, var(--color-bg));
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary, var(--color-text-primary));
}

.footer-onion-copy {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: color var(--transition-fast);
}

.footer-onion-copy:hover,
.footer-onion-copy.copied {
    color: var(--color-accent);
}

.footer-links {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
}

.footer-link {
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    transition: color var(--transition-fast);
}

.footer-link:hover {
    color: var(--color-text-primary);
}

.footer-sep {
    color: var(--color-text-muted);
    user-select: none;
}

.footer-made {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

.footer-repo {
    color: var(--color-accent);
    transition: color var(--transition-fast);
}

.footer-repo:hover {
    color: var(--color-text-primary);
}

.footer-version {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
}

.footer-update {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
}

.footer-update:hover {
    color: var(--color-accent);
}

.footer-commit {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
}

.footer-commit:hover {
    color: var(--color-accent);
}

.footer-meta {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
}

/* ============================================
   Loading & Empty States
   ============================================ */
.loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) 0;
}

.loading-spinner {
    width: 48px;
    height: 48px;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-accent-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading-text {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

.empty-state {
    text-align: center;
    padding: var(--space-16) 0;
}

.empty-icon {
    font-size: 64px;
    margin-bottom: var(--space-4);
    opacity: 0.3;
}

.empty-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-2);
}

.empty-description {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
}

/* ============================================
   Responsive Design — MOBILE-FIRST
   Base styles target mobile (<768px).
   min-width queries progressively enhance for larger screens.
   ============================================ */

/* Mobile base overrides for large typographic tokens */
:root {
    --font-size-5xl: 2.5rem;
    --font-size-4xl: 2rem;
    --font-size-3xl: 1.5rem;
}

/* Mobile nav: stack vertically */
.nav {
    height: auto;
    padding: var(--space-4);
    flex-direction: column;
    gap: var(--space-4);
}

.nav-links {
    width: 100%;
    justify-content: center;
    flex-wrap: wrap;
}

/* Mobile hero */
.hero {
    padding: var(--space-10) 0 var(--space-8);
}

.hero-actions {
    flex-direction: column;
    align-items: center;
}

.hero-stats {
    flex-direction: column;
    gap: var(--space-6);
}

/* Mobile grids: single column */
.features-grid {
    grid-template-columns: 1fr;
}

.form-grid {
    grid-template-columns: 1fr;
}

.results-grid {
    grid-template-columns: 1fr;
}

/* Tablet (768px+): restore larger-screen type scale and layout */
@media (min-width: 768px) {
    :root {
        --font-size-5xl: 3.5rem;
        --font-size-4xl: 2.5rem;
        --font-size-3xl: 2rem;
    }

    .nav {
        height: 72px;
        padding: 0 var(--space-6);
        flex-direction: row;
        gap: 0;
    }

    .nav-links {
        width: auto;
        justify-content: flex-end;
        flex-wrap: nowrap;
    }

    .hero-actions {
        flex-direction: row;
        align-items: flex-start;
    }

    .hero-stats {
        flex-direction: row;
        gap: var(--space-8);
    }

    .features-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .form-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .results-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Desktop (1024px+): full desktop grid layouts */
@media (min-width: 1024px) {
    .features-grid {
        grid-template-columns: repeat(3, 1fr);
    }

    .results-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* ============================================
   Animations
   ============================================ */
@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.animate-fade-in-up {
    animation: fadeInUp 0.5s ease forwards;
}

/* Stagger animations */
.results-grid > * {
    animation: fadeInUp 0.4s ease forwards;
    opacity: 0;
}

.results-grid > *:nth-child(1) { animation-delay: 0.05s; }
.results-grid > *:nth-child(2) { animation-delay: 0.1s; }
.results-grid > *:nth-child(3) { animation-delay: 0.15s; }
.results-grid > *:nth-child(4) { animation-delay: 0.2s; }
.results-grid > *:nth-child(5) { animation-delay: 0.25s; }
.results-grid > *:nth-child(6) { animation-delay: 0.3s; }

/* ============================================
   Utility Classes
   ============================================ */
.hidden { display: none !important; }
.text-center { text-align: center; }
.text-muted { color: var(--color-text-muted); }
.mt-4 { margin-top: var(--space-4); }
.mt-8 { margin-top: var(--space-8); }
.mb-4 { margin-bottom: var(--space-4); }
.mb-8 { margin-bottom: var(--space-8); }
.ml-auto { margin-left: auto; }

/* ============================================
   Long String Utilities (PART 16)
   Required for IPv6, .onion, tokens, hashes, UUIDs, Base64
   ============================================ */
.long-string,
.ip-address,
.onion-address,
.api-token,
.hash,
.uuid,
.monospace-data {
    word-break: break-all;
    overflow-wrap: break-word;
    font-family: monospace;
}

/* ============================================
   Extended Form Styles
   ============================================ */
.search-form {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    margin-bottom: var(--space-6);
}

.form-input-lg {
    padding: var(--space-4) var(--space-5);
    font-size: var(--font-size-lg);
    border-radius: var(--radius-lg);
}

.form-hint {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-1);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
}

@media (min-width: 641px) {
    .form-row {
        grid-template-columns: repeat(2, 1fr);
    }
}

.btn-block {
    width: 100%;
}

.btn-icon {
    font-size: 1.2em;
}

.btn-group {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
}

.btn-group .btn {
    flex: 1;
    min-width: 180px;
}

/* ============================================
   Result Cards Extended
   ============================================ */
.result-card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-4);
    gap: var(--space-3);
}

.result-card-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text-primary);
}

.result-card-badge {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-xs);
    font-weight: 700;
    background: var(--color-accent-gradient);
    color: var(--color-on-accent);
    border-radius: var(--radius-full);
    flex-shrink: 0;
}

.result-card-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
}

@media (min-width: 481px) {
    .result-card-body {
        grid-template-columns: repeat(3, 1fr);
    }
}

.result-card-stat {
    text-align: center;
    padding: var(--space-3);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
}

.result-card-stat-label {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
}

.result-card-stat-value {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    font-family: var(--font-mono);
}

.result-card-stat-highlight {
    background: var(--color-accent-tint-strong);
}

.result-card-stat-highlight .result-card-stat-value {
    color: var(--color-accent-primary);
}

.result-card-featured {
    border-color: var(--color-accent-primary);
    box-shadow: 0 0 20px var(--color-accent-glow);
}

/* ============================================
   Loading & Empty States Extended
   ============================================ */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-12) 0;
    color: var(--color-text-muted);
}

.loading-state p {
    margin-top: var(--space-4);
    font-size: var(--font-size-sm);
}

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-12) 0;
}

.empty-state-icon {
    font-size: 64px;
    margin-bottom: var(--space-4);
    opacity: 0.5;
}

.empty-state-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
}

.empty-state-description {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

/* ============================================
   Location Status
   ============================================ */
.location-status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4);
    background: var(--color-accent-tint);
    border: 1px solid var(--color-accent-primary);
    border-radius: var(--radius-lg);
    margin-top: var(--space-4);
}

.location-status-icon {
    font-size: 20px;
    animation: bounce 1s infinite;
}

@keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}

.location-status-text {
    font-size: var(--font-size-sm);
    color: var(--color-accent-primary);
}

/* ============================================
   API Documentation Extended
   ============================================ */
.api-docs {
    padding: var(--space-8) 0;
}

.api-section-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 2px solid var(--color-border);
}

.api-overview {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
}

@media (min-width: 641px) {
    .api-overview {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 1024px) {
    .api-overview {
        grid-template-columns: repeat(4, 1fr);
    }
}

.api-overview-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
}

.api-overview-icon {
    font-size: 32px;
    flex-shrink: 0;
}

.api-overview-content h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--space-1);
}

.api-overview-content p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
}

.api-download {
    text-align: center;
    margin-bottom: var(--space-8);
}

.api-endpoint {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
    overflow: hidden;
}

.api-endpoint-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: var(--color-bg-tertiary);
    border-bottom: 1px solid var(--color-border);
}

.api-method {
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-xs);
    font-weight: 700;
    font-family: var(--font-mono);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
}

.api-method-get {
    background: var(--color-success-tint);
    color: var(--color-success);
}

.api-method-post {
    background: var(--color-info-tint);
    color: var(--color-info);
}

.api-method-put {
    background: var(--color-warning-tint);
    color: var(--color-warning);
}

.api-method-delete {
    background: var(--color-error-tint);
    color: var(--color-error);
}

.api-path {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    background: transparent;
    padding: 0;
}

.api-endpoint-body {
    padding: var(--space-5);
}

.api-endpoint-description {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
}

.api-params {
    margin-top: var(--space-4);
}

.api-params-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
    margin-top: var(--space-4);
}

.api-params-title:first-child {
    margin-top: 0;
}

.api-params-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
}

.api-params-table th,
.api-params-table td {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
}

.api-params-table th {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-bg-tertiary);
}

.api-params-table td {
    color: var(--color-text-secondary);
}

.api-params-table td code {
    color: var(--color-text-primary);
}

.api-params-table tr:last-child td {
    border-bottom: none;
}

.api-required {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--color-error);
    background: var(--color-error-tint-soft);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    margin-left: var(--space-2);
}

.api-note {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    padding: var(--space-3);
    background: var(--color-bg-tertiary);
    border-radius: var(--radius-md);
    margin-top: var(--space-3);
}

.api-response-examples {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
}

.api-response-example {
    margin-bottom: var(--space-4);
}

.api-response-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    margin-bottom: var(--space-3);
}

/* ============================================
   Pastebin-Specific Styles
   ============================================ */

/* Paste Content Viewer */
.paste-view {
    max-width: 1000px;
    margin: 0 auto;
}

.paste-header {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    padding: var(--space-5);
}

.paste-header h1 {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--space-3);
    word-break: break-word;
}

.paste-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
}

.paste-meta span {
    display: flex;
    align-items: center;
    gap: var(--space-2);
}

.paste-meta .language {
    background: var(--color-accent-gradient);
    color: var(--color-on-accent);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: var(--font-size-xs);
}

.paste-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
}

.paste-content {
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-top: none;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    overflow: hidden;
}

.paste-content pre {
    margin: 0;
    padding: var(--space-5);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    color: var(--color-text-primary);
    background: transparent;
}

.paste-content code {
    background: transparent;
    padding: 0;
    font-size: inherit;
}

/* Binary paste rendering: images and media players */
.paste-image {
    padding: var(--space-5);
}

.paste-image img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
    border-radius: var(--radius-md);
}

.paste-media {
    padding: var(--space-5);
}

.paste-media audio {
    display: block;
    width: 100%;
}

.paste-media video {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
}

.paste-binary {
    padding: var(--space-5);
}

/* Embed snippets: copy-ready HTML/Markdown iframe code under the paste */
.embed-snippets {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
    margin-top: var(--space-4);
}

.embed-snippets-title {
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
}

.embed-snippet {
    margin-bottom: var(--space-3);
}

.embed-snippet:last-child {
    margin-bottom: 0;
}

.embed-snippet-label {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-1);
}

.embed-snippet-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.embed-snippet-row .btn {
    min-height: 44px;
}

.embed-snippet-input {
    flex: 1;
    min-height: 44px;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    word-break: break-all;
    overflow-wrap: break-word;
}

@media (min-width: 768px) {
    .embed-snippet-row {
        flex-direction: row;
        align-items: stretch;
    }
}

/* Paste List Items */
.pastes-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
}

.paste-item {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-5);
    transition: all var(--transition-fast);
}

.paste-item:hover {
    border-color: var(--color-accent-primary);
    transform: translateX(4px);
}

.paste-title {
    display: block;
    font-size: var(--font-size-base);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
    text-decoration: none;
}

.paste-title:hover {
    color: var(--color-accent-primary);
}

.paste-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
}

.paste-item-meta .language {
    background: var(--color-accent-tint-strong);
    color: var(--color-accent-primary);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-weight: 600;
}

/* Create Paste Form */
.paste-form {
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
}

.paste-form textarea {
    min-height: 400px;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    line-height: 1.6;
    resize: vertical;
}

.paste-form .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
}

@media (min-width: 769px) {
    .paste-form .form-row {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* Pagination */
.pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
    padding: var(--space-4);
}

.pagination button {
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    font-weight: 500;
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
}

.pagination button:hover:not(:disabled) {
    background: var(--color-bg-hover);
    border-color: var(--color-accent-primary);
}

.pagination button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.pagination span {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

/* Result Success */
.result .success {
    background: var(--color-success-tint-soft);
    border: 1px solid var(--color-success);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-top: var(--space-6);
}

.result .success h3 {
    color: var(--color-success);
    margin-bottom: var(--space-3);
}

.result .success a {
    color: var(--color-accent-primary);
    word-break: break-all;
}

.result .error {
    background: var(--color-error-tint-soft);
    border: 1px solid var(--color-error);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    margin-top: var(--space-4);
    color: var(--color-error);
}

/* Hidden utility */
.hidden {
    display: none !important;
}

/* Danger button */
.btn-danger {
    background: var(--color-error);
    color: var(--color-on-accent);
}

.btn-danger:hover {
    background: var(--color-error-strong);
    color: var(--color-on-accent);
    transform: translateY(-1px);
}

/* Alert banners */
.alert {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-3);
}

.alert-error {
    background: var(--color-error-tint-12);
    border: 1px solid var(--color-error);
    color: var(--color-error);
}

.alert-warning {
    background: var(--color-warning-tint-12);
    border: 1px solid var(--color-warning);
    color: var(--color-warning);
}

.alert-success {
    background: var(--color-success-tint-12);
    border: 1px solid var(--color-success);
    color: var(--color-success);
}

/* ============================================
   Feature List (about page)
   ============================================ */
.feature-list {
    line-height: 2;
    padding-left: var(--space-6);
}

/* ============================================
   Spacing Utilities
   ============================================ */
.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mb-2 { margin-bottom: var(--space-2); }
.d-block { display: block; }

/* ============================================
   Text Color Utilities
   ============================================ */
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }

/* ============================================
   Toast Notification System (PART 16)
   ============================================ */
#toast-container {
    position: fixed;
    bottom: var(--space-4);
    right: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    z-index: 10000;
    pointer-events: none;
}

.toast {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    color: var(--color-text-primary);
    box-shadow: var(--shadow-lg);
    pointer-events: auto;
    animation: toastIn 0.2s ease forwards;
    min-width: 200px;
    max-width: 400px;
}

.toast--info { border-left: 4px solid var(--color-info); }
.toast--success { border-left: 4px solid var(--color-success); }
.toast--warning { border-left: 4px solid var(--color-warning); }
.toast--error { border-left: 4px solid var(--color-error); }

@keyframes toastIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes toastOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(8px); }
}

.toast--dismissing {
    animation: toastOut 0.2s ease forwards;
}

/* ============================================
   Skip Link (WCAG 2.1 AA — PART 16)
   ============================================ */
.skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    z-index: 20000;
    padding: var(--space-2) var(--space-4);
    background: var(--color-accent-primary);
    color: var(--color-on-accent);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-decoration: none;
    transition: top var(--transition-fast);
}

.skip-link:focus {
    top: var(--space-4);
}

/* ============================================
   Theme Toggle Button (PART 16)
   ============================================ */
.theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-secondary);
    cursor: pointer;
    font-size: 18px;
    transition: all var(--transition-fast);
    flex-shrink: 0;
}

.theme-toggle:hover {
    background: var(--color-bg-hover);
    color: var(--color-text-primary);
    border-color: var(--color-border-hover);
}

/* ============================================
   Offline Indicator (PART 16)
   ============================================ */
#offline-indicator {
    position: fixed;
    bottom: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    padding: var(--space-2) var(--space-5);
    background: var(--color-warning);
    color: var(--color-text-inverse);
    border-radius: var(--radius-full);
    font-size: var(--font-size-sm);
    font-weight: 600;
    z-index: 9000;
    box-shadow: var(--shadow-md);
}

/* ============================================
   SW Update Banner (PART 16)
   ============================================ */
.sw-update-banner {
    position: fixed;
    bottom: var(--space-4);
    right: var(--space-4);
    background: var(--accent, var(--color-accent-primary));
    color: #fff;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    display: flex;
    gap: var(--space-2);
    align-items: center;
    font-size: var(--font-size-sm);
    z-index: 9999;
    box-shadow: var(--shadow-lg);
}

.sw-update-banner__btn-apply {
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: inherit;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-sm);
    cursor: pointer;
}

.sw-update-banner__btn-apply:hover {
    background: rgba(255, 255, 255, 0.35);
}

.sw-update-banner__btn-dismiss {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: var(--space-1);
}

/* ============================================
   QR Page Utilities (PART 16)
   ============================================ */
.qr-container {
    display: inline-block;
    padding: var(--space-6);
}

.qr-image {
    display: block;
    margin: 0 auto;
    max-width: 300px;
    width: 100%;
}

.qr-link-text {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    word-break: break-all;
}

.qr-actions {
    justify-content: center;
    margin-top: var(--space-4);
}

/* ============================================
   Page Section Utilities (PART 16)
   ============================================ */
.page-view {
    padding: var(--space-6);
}

.section-mt {
    margin-top: var(--space-6);
}

.section-mt-sm {
    margin-top: var(--space-4);
}

.page-centered {
    text-align: center;
}

.delete-success-icon {
    font-size: 3rem;
    margin-bottom: var(--space-4);
}

.delete-hint {
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
}

.help-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: var(--space-3);
}

.help-table th,
.help-table td {
    text-align: left;
    padding: var(--space-1) var(--space-3);
}

.help-table th {
    font-weight: 600;
}

.form-mono {
    font-family: monospace;
}

.token-hint {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin-top: var(--space-2);
}

/* ============================================
   Embed Widget (emb.html)
   ============================================ */
.emb-wrap {
    padding: var(--space-2);
}

.emb-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-2);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
}

.emb-header .lang {
    font-weight: 600;
    color: var(--color-text-primary);
}

.emb-body {
    overflow: auto;
    max-height: 90vh;
}

.emb-body pre {
    margin: 0;
    padding: var(--space-3);
    font-size: var(--font-size-sm);
}

/* ============================================
   Health Status Page (healthz.html)
   ============================================ */
.health-header {
    text-align: center;
    padding: var(--space-6) 0 var(--space-4);
}

.health-header h1 {
    font-size: var(--font-size-3xl);
    margin-bottom: var(--space-2);
}

.health-header .tagline {
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
}

.status-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-radius: var(--radius-lg);
    margin: var(--space-4) 0;
    font-size: var(--font-size-lg);
    font-weight: 600;
}

.status-ok {
    background: var(--color-success-tint);
    color: var(--color-success);
    border: 1px solid var(--color-success);
}

.status-error {
    background: var(--color-error-tint);
    color: var(--color-error);
    border: 1px solid var(--color-error);
}

.status-warning {
    background: var(--color-warning-tint);
    color: var(--color-warning);
    border: 1px solid var(--color-warning);
}

.section-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    margin-bottom: var(--space-4);
}

.section-card h2 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-4);
}

.info-list {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2) var(--space-4);
}

.info-list dt {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
}

.info-list dd {
    margin: 0;
}

.badge {
    display: inline-block;
    padding: 0.15em 0.6em;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 600;
}

.badge-production {
    background: var(--color-accent-tint-strong);
    color: var(--color-accent-hover);
}

.badge-development {
    background: var(--color-warning-tint);
    color: var(--color-warning);
}

.data-table {
    width: 100%;
    border-collapse: collapse;
}

.data-table th {
    text-align: left;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
}

.data-table td {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
}

.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-size: var(--font-size-sm);
    font-weight: 600;
}

.status-badge.ok {
    color: var(--color-success);
}

.status-badge.error {
    color: var(--color-error);
}

.feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
}

.feature-enabled {
    color: var(--color-text-primary);
}

.feature-disabled {
    color: var(--color-text-muted);
    text-decoration: line-through;
}

.stat-number {
    font-size: var(--font-size-xl);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
}

/* ============================================
   Offline Page (offline.html)
   ============================================ */
.offline-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: var(--space-8);
}

.offline-icon {
    font-size: 4rem;
    margin-bottom: var(--space-6);
    opacity: 0.7;
}

.offline-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
}

.offline-message {
    color: var(--color-text-muted);
    max-width: 480px;
    margin-bottom: var(--space-8);
    line-height: 1.6;
}

/* ============================================
   Error Pages (PART 16 — themed 4xx/5xx)
   ============================================ */
.error-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    padding: var(--space-8);
}

.error-code {
    font-size: 6rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: var(--space-3);
    color: var(--color-accent-primary);
}

.error-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
}

.error-message {
    color: var(--color-text-muted);
    max-width: 480px;
    margin-bottom: var(--space-8);
    line-height: 1.6;
    word-break: break-word;
    overflow-wrap: break-word;
}

.error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
}

/* ============================================
   Reduced Motion (WCAG 2.1 AA — PART 16)
   ============================================ */
@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
    }
}

/* ============================================
   Cookie Consent Banner and Preferences (PART 31)
   ============================================ */

.cookie-banner {
    position: fixed;
    left: 0;
    right: 0;
    width: 100%;
    background: var(--color-bg-elevated);
    color: var(--color-text-primary);
    border-top: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    z-index: 9990;
}

.cookie-banner-bottom {
    bottom: 0;
}

.cookie-banner-top {
    top: 0;
    border-top: none;
    border-bottom: 1px solid var(--color-border);
}

.cookie-banner-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-4);
    max-width: 1100px;
    margin: 0 auto;
}

.cookie-message {
    text-align: center;
    font-size: var(--font-size-sm);
    line-height: 1.5;
}

.cookie-banner .policy-link {
    color: var(--color-accent-primary);
    text-decoration: underline;
}

.cookie-banner .policy-link:hover {
    color: var(--color-accent-hover);
}

.cookie-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
    flex-shrink: 0;
}

.cookie-banner button {
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    font-size: var(--font-size-sm);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: background var(--transition-fast), opacity var(--transition-fast);
}

.cookie-banner .btn-decline,
.cookie-banner .btn-preferences,
.cookie-banner .btn-do-not-sell {
    background: transparent;
    border: 1px solid var(--color-border-hover);
    color: var(--color-text-primary);
}

.cookie-banner .btn-decline:hover,
.cookie-banner .btn-preferences:hover,
.cookie-banner .btn-do-not-sell:hover {
    background: var(--color-bg-hover);
}

.cookie-banner .btn-accept {
    background: var(--color-accent-primary);
    border: 1px solid var(--color-accent-primary);
    color: var(--color-on-accent);
    font-weight: 600;
}

.cookie-banner .btn-accept:hover {
    background: var(--color-accent-hover);
}

.cookie-modal-overlay {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
    background: rgba(0, 0, 0, 0.6);
    z-index: 10010;
}

.cookie-modal {
    width: 100%;
    max-width: 480px;
    max-height: 90vh;
    overflow-y: auto;
    padding: var(--space-6);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
}

.cookie-modal-title {
    margin: 0 0 var(--space-5);
    font-size: var(--font-size-xl);
    color: var(--color-text-primary);
}

.cookie-category {
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
}

.cookie-category-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-height: 44px;
    cursor: pointer;
}

.cookie-category-head input[type="checkbox"] {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    accent-color: var(--color-accent-primary);
}

.cookie-category-head input[type="checkbox"]:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.cookie-category-label {
    font-weight: 600;
    color: var(--color-text-primary);
}

.cookie-category-desc {
    margin: var(--space-2) 0 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
}

.cookie-modal-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: flex-end;
    margin-top: var(--space-6);
}

.cookie-modal-actions button {
    min-height: 44px;
    padding: var(--space-2) var(--space-5);
    font-size: var(--font-size-sm);
    border-radius: var(--radius-sm);
    cursor: pointer;
}

.cookie-modal-actions .btn-decline {
    background: transparent;
    border: 1px solid var(--color-border-hover);
    color: var(--color-text-primary);
}

.cookie-modal-actions .btn-decline:hover {
    background: var(--color-bg-hover);
}

.cookie-modal-actions .btn-accept {
    background: var(--color-accent-primary);
    border: 1px solid var(--color-accent-primary);
    color: var(--color-on-accent);
    font-weight: 600;
}

.cookie-modal-actions .btn-accept:hover {
    background: var(--color-accent-hover);
}

@media (min-width: 768px) {
    .cookie-banner-content {
        flex-direction: row;
        justify-content: space-between;
        gap: var(--space-8);
        padding: var(--space-4) var(--space-6);
    }

    .cookie-message {
        text-align: left;
    }
}


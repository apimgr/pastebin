{{define "meta"}}
    <title>Report Status - {{.SiteTitle}}</title>
{{end}}

{{define "content"}}
        <section class="search-section">
            <div class="container container-sm">
                <div class="section-header">
                    <h1 class="section-title">Security Report Status</h1>
                    <p class="section-subtitle long-string">Tracking ID: <code>{{.TrackingID}}</code></p>
                </div>

                <div class="paste-view page-view">
                    {{if .RateLimited}}
                    <div class="alert alert-warning" role="alert">
                        This status link may only be opened once per day. You are seeing the last
                        loaded state; please check back tomorrow for a fresh view.
                    </div>
                    {{end}}

                    <dl class="detail-list">
                        <div class="detail-row">
                            <dt>Current status</dt>
                            <dd><strong>{{.Status}}</strong></dd>
                        </div>
                        <div class="detail-row">
                            <dt>Severity</dt>
                            <dd>{{if .Severity}}{{.Severity}}{{else}}Pending triage{{end}}</dd>
                        </div>
                        <div class="detail-row">
                            <dt>Component</dt>
                            <dd>{{if .Component}}{{.Component}}{{else}}—{{end}}</dd>
                        </div>
                        <div class="detail-row">
                            <dt>Received</dt>
                            <dd>{{.ReceivedAt}}</dd>
                        </div>
                        <div class="detail-row">
                            <dt>Last updated</dt>
                            <dd>{{.UpdatedAt}}</dd>
                        </div>
                        <div class="detail-row">
                            <dt>Expected disclosure</dt>
                            <dd>{{.ExpectedDate}}</dd>
                        </div>
                        {{if .DisclosedAt}}
                        <div class="detail-row">
                            <dt>Disclosed</dt>
                            <dd>{{.DisclosedAt}}</dd>
                        </div>
                        {{end}}
                    </dl>

                    <h2 class="section-mt">Progress</h2>
                    <ol class="progress-stages">
                        {{range .Stages}}
                        <li class="progress-stage{{if eq . $.CurrentStage}} progress-stage-current{{end}}">{{.}}</li>
                        {{end}}
                    </ol>

                    {{if .Comment}}
                    <h2 class="section-mt">Maintainer note</h2>
                    <blockquote class="maintainer-comment">{{.Comment}}</blockquote>
                    {{end}}

                    <h2 class="section-mt">Contact</h2>
                    <p>
                        To add information to this report, reply to the acknowledgment email
                        {{if .SecurityEmail}}or write to
                        <a href="mailto:{{.SecurityEmail}}" class="long-string">{{.SecurityEmail}}</a>{{end}}
                        and include your tracking ID.
                    </p>
                </div>
            </div>
        </section>
{{end}}

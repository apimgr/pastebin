{{define "meta"}}
    <title>Delete Paste - {{.SiteTitle}}</title>
    <meta name="description" content="Permanently delete a paste using its delete token">
{{end}}

{{define "content"}}
        <section class="search-section">
            <div class="container container-sm">
                <div class="section-header">
                    <h1 class="section-title">{{t .Lang "paste.delete_title"}}</h1>
                    <p class="section-description">{{t .Lang "paste.delete_desc"}}</p>
                </div>

                {{if .Success}}
                <div class="paste-view page-view page-centered">
                    <div class="delete-success-icon">🗑️</div>
                    <h2>{{t .Lang "paste.deleted_title"}}</h2>
                    <p class="delete-hint">
                        Paste <code>{{.ID}}</code> has been permanently deleted.
                    </p>
                    <a href="{{.AssetPrefix}}/" class="btn btn-primary">{{t .Lang "paste.go_home"}}</a>
                    <a href="{{.AssetPrefix}}/create" class="btn btn-secondary">{{t .Lang "paste.create_new_paste"}}</a>
                </div>
                {{else}}
                <div class="paste-view">
                    {{if .Error}}
                    <div class="alert alert-error">
                        {{.Error}}
                    </div>
                    {{end}}

                    <form action="{{.AssetPrefix}}/remove/{{.ID}}" method="POST" class="paste-form">
                        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                        <div class="form-group">
                            <label for="token" class="form-label">{{t .Lang "paste.delete_token_label"}}</label>
                            <input
                                type="text"
                                id="token"
                                name="token"
                                class="form-input form-mono"
                                placeholder="Paste your delete token here"
                                required
                                autocomplete="off"
                                data-token-error="{{if .Error}}true{{else}}false{{end}}"
                            >
                            <p class="token-hint">
                                This is the token you received when the paste was created. This action cannot be undone.
                            </p>
                        </div>
                        <div class="form-actions">
                            <a href="{{.AssetPrefix}}/{{.ID}}" class="btn btn-secondary">{{t .Lang "paste.cancel"}}</a>
                            <button type="submit" class="btn btn-danger">{{t .Lang "paste.delete_btn"}}</button>
                        </div>
                    </form>
                </div>
                {{end}}
            </div>
        </section>
{{end}}

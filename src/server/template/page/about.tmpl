{{define "meta"}}
    <title>About - {{.SiteTitle}}</title>
    <meta name="description" content="About {{.SiteTitle}} — a simple, fast paste sharing service with syntax highlighting and API access">
{{end}}

{{define "content"}}
        <section class="search-section">
            <div class="container container-sm">
                <div class="section-header">
                    <h1 class="section-title">{{t .Lang "about.title"}} {{.SiteTitle}}</h1>
                </div>

                <div class="paste-view page-view">
                    <p class="lead">{{.Tagline}}</p>

                    <h2>What is {{.SiteTitle}}?</h2>
                    <p>{{.Description}}</p>

                    <h2 class="section-mt">{{t .Lang "about.features"}}</h2>
                    <ul class="feature-list">
                        {{range .Features}}<li>{{.}}</li>
                        {{end}}
                    </ul>

                    <h2 class="section-mt">{{t .Lang "about.version"}}</h2>
                    <p class="long-string">{{.Version}} ({{.BuildDate}})</p>

                    <h2 class="section-mt">Source</h2>
                    <p class="about-links">
                        {{range .Links}}<a href="{{.URL}}" target="_blank" rel="noopener">{{.Label}}</a>
                        {{end}}
                    </p>
                    <p>Open source, MIT licensed.</p>
                </div>
            </div>
        </section>
{{end}}

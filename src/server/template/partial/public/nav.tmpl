{{define "nav"}}
            <div class="nav-links">
                <a href="{{.AssetPrefix}}/" class="nav-link{{if eq .CurrentPath (print .AssetPrefix "/")}} active{{end}}">{{t .Lang "nav.home"}}</a>
                <a href="{{.AssetPrefix}}/create" class="nav-link{{if eq .CurrentPath (print .AssetPrefix "/create")}} active{{end}}">{{t .Lang "nav.create"}}</a>
                <a href="{{.AssetPrefix}}/recent" class="nav-link{{if eq .CurrentPath (print .AssetPrefix "/recent")}} active{{end}}">{{t .Lang "nav.recent"}}</a>
                <form class="theme-toggle" method="post" action="/theme"><input type="hidden" name="csrf_token" value="{{.CSRFToken}}"><input type="hidden" name="theme" value="{{.NextTheme}}"><button type="submit" class="theme-button" data-theme-toggle aria-label="Toggle theme">🌙</button></form>
            </div>
{{end}}

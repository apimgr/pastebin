{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "pinDigests": true,
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "automerge": false,
      "pinDigests": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  }
}

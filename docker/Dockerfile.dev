# =============================================================================
# Development Image (:devel)
# Runs the binary in development mode with live source mounted.
# All OCI metadata is applied via --annotation at build time; no LABEL blocks.
# =============================================================================
FROM casjaysdev/go:latest AS builder

ARG TARGETARCH
ARG VERSION=devel
ARG BUILD_DATE
ARG COMMIT_ID

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH:-amd64} go build \
    -buildvcs=false -trimpath \
    -ldflags "-s -w -X 'main.Version=${VERSION}' \
              -X 'main.CommitID=${COMMIT_ID}' \
              -X 'main.BuildDate=${BUILD_DATE}'" \
    -o /app/pastebin ./src

# =============================================================================
FROM alpine:latest

RUN apk add --no-cache \
    git \
    curl \
    bash \
    tini \
    tor

COPY --from=builder /app/pastebin /usr/local/bin/pastebin
COPY docker/rootfs/ /

RUN chmod 755 /usr/local/bin/pastebin

# Development defaults
ENV TZ=America/New_York \
    MODE=development \
    DEBUG=true \
    DATABASE_DIR=/data/db/sqlite

EXPOSE 80
# termbin/fiche raw-TCP compat listener (only binds when TERMBIN_ENABLED is truthy)
EXPOSE 9999

STOPSIGNAL SIGRTMIN+3

HEALTHCHECK --start-period=10m --interval=5m --timeout=15s --retries=3 \
    CMD /usr/local/bin/pastebin --status || exit 1

ENTRYPOINT ["tini", "-p", "SIGTERM", "--", "/usr/local/bin/entrypoint.sh"]
